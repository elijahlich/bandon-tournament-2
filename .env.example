# Copy this file to ".env" and fill in your Firebase project values.
# See README.md → "Step 4: Get your Firebase config" for where to find these.
#
# These values are NOT secret. They identify your Firebase project to the SDK,
# but security is enforced by Firestore rules, not by hiding these keys.
# You can safely commit a real .env to a private repo (just don't commit it
# to a public repo as a matter of hygiene).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
